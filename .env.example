DATABASE_URL="postgresql://postgres:password@host:port/database"
JWT_SECRET="shared-secret-from-auth-hub"
APP_BASE_URL="http://localhost:3000"
AUTH_HUB_URL="https://auth.atap.solar"

# WhatsApp Referral Assistant.
# Database access (reuses SANDBOX proxy values if these are omitted).
WHATSAPP_AGENT_PROXY_URL="https://pg-proxy-production.up.railway.app"
WHATSAPP_AGENT_PROXY_AUTH="Bearer ..."
WHATSAPP_AGENT_PROXY_DB_NAME="prod_main"

# Baileys WhatsApp server used to SEND replies.
WHATSAPP_AGENT_BAILEYS_BASE_URL="https://ee-baileys-2.up.railway.app"
WHATSAPP_AGENT_BAILEYS_SESSION_ID="0182920127"
WHATSAPP_AGENT_TENANT_ID="1"
# Worker polls unreplied inbound WhatsApp rows in et_messages.
WHATSAPP_AGENT_DB_LOOKBACK_MINUTES="60"

# LLM that powers the agent (MiniMax-M3 via its Anthropic-compatible endpoint).
# REQUIRED in production — without it the agent cannot reply.
MINIMAX_API_KEY="sk-cp-..."
WHATSAPP_AGENT_LLM_BASE_URL="https://api.minimax.io"
WHATSAPP_AGENT_LLM_MODEL="MiniMax-M3"

# Voice-note transcription before the agent turn.
# UniAPI's Gemini-compatible endpoint is the verified provider path.
WHATSAPP_AGENT_ASR_PROVIDER="uniapi"
WHATSAPP_AGENT_UNIAPI_BASE_URL="https://api.uniapi.io/gemini"
WHATSAPP_AGENT_UNIAPI_API_KEY=""
WHATSAPP_AGENT_UNIAPI_ASR_MODEL="gemini-3.5-flash"

# Image OCR / visual extraction. Required for image messages.
WHATSAPP_AGENT_VISION_BASE_URL="https://api.apikey.fun/v1"
WHATSAPP_AGENT_VISION_API_KEY=""
WHATSAPP_AGENT_VISION_MODEL="gpt-5.4-mini"

# Phones (no +) that may view all referral leads.
WHATSAPP_AGENT_SUPER_ADMIN_PHONES="601121000099"

# Required in production: shared secret for the worker and manual process route.
WHATSAPP_AGENT_PROCESS_SECRET=""
# Required in production for diagnostics and agent logs.
WHATSAPP_AGENT_DEBUG_SECRET=""
# Optional: token for Meta-style GET webhook verification (hub.verify_token).
WHATSAPP_AGENT_WEBHOOK_VERIFY_TOKEN=""
# Required in production for inbound POST webhooks.
WHATSAPP_AGENT_WEBHOOK_SECRET=""
